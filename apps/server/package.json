{
  "name": "@team-culture-sim/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsc && concurrently -n tsc,api -c gray,blue \"tsc -w --preserveWatchOutput\" \"node --watch dist/index.js\"",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@team-culture-sim/content": "*",
    "@team-culture-sim/sim-engine": "*",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
