modules = ["nodejs-20", "web", "bash", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/replit-dev.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3001

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8787
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "PORT=5000 node apps/server/dist/index.js"]
build = ["bash", "-c", "npm run build -w @team-culture-sim/sim-engine && npm run build -w @team-culture-sim/server && npm run build -w @team-culture-sim/web"]
