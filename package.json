{
  "name": "team-culture-sim",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "restart": "bash scripts/restart-dev.sh",
    "dev:web": "npm run dev -w @team-culture-sim/web",
    "dev:server": "npm run dev -w @team-culture-sim/server",
    "build": "npm run build -w @team-culture-sim/sim-engine && npm run build -w @team-culture-sim/web",
    "test": "npm run test -w @team-culture-sim/sim-engine",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
